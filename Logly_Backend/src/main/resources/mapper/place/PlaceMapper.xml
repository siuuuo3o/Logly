<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.siuuuuu.logly_backend.domain.place.mapper.PlaceMapper">

    <resultMap id="PlaceResultMap" type="com.siuuuuu.logly_backend.domain.place.dto.PlaceResponse">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="address" column="address"/>
        <result property="latitude" column="latitude"/>
        <result property="longitude" column="longitude"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="PlaceResultMap">
        SELECT id, name, address, latitude, longitude, created_at
        FROM place
        WHERE id = #{id}
    </select>

</mapper>

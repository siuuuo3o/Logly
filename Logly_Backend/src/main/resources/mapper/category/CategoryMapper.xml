<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.siuuuuu.logly_backend.domain.category.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="com.siuuuuu.logly_backend.domain.category.dto.CategoryResponse">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="color" column="color"/>
        <result property="icon" column="icon"/>
        <result property="isDefault" column="is_default"/>
    </resultMap>

    <select id="findAllByUserId" resultMap="CategoryResultMap">
        SELECT id, name, color, icon, is_default
        FROM category
        WHERE user_id = #{userId}
        ORDER BY is_default DESC, id ASC
    </select>

    <select id="findById" resultMap="CategoryResultMap">
        SELECT id, name, color, icon, is_default
        FROM category
        WHERE id = #{id}
    </select>

</mapper>
